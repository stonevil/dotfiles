			<action name="SendToDesktop"><to>10</to></action>
		</keybind>

		<keybind key="W-A-S-Left">
			<action name="MoveToOutput" direction="left"></action>
		</keybind>

		<keybind key="W-S-A-Right">
			<action name="MoveToOutput" direction="right"></action>
		</keybind>

		<keybind key="W-S-3">
			<action name="Execute" command="hyprshot -m output" />
		</keybind>
		<keybind key="W-S-4">
			<action name="Execute" command="hyprshot -m window" />
		</keybind>
		<keybind key="W-S-5">
			<action name="Execute" command="hyprshot -m region" />
		</keybind>
		<keybind key="PRINT">
			<action name="Execute" command="hyprshot -m window" />
		</keybind>
		<keybind key="S-PRINT">
			<action name="Execute" command="hyprshot -m region" />
		</keybind>

		<keybind key="W-C-l">
			<action name="Execute" command="playerctl --all-players pause" />
			<action name="Execute" command="loginctl lock-session" />
		</keybind>
		<keybind key="W-C-S-q">
			<action name="Execute" command="systemctl suspend" />
		</keybind>
		<keybind key="W-C-A-q">
