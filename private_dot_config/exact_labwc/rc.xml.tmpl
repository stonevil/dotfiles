			<action name="Execute" command="{{ print (joinPath .chezmoi.homeDir ".config/wayland/scripts/brightness") " " "down" }}" />
		</keybind>
		<keybind key="XF86Launch1">
			<action name="Execute" command="rog-control-center" />
		</keybind>

		<!-- GoToDesktop by number -->
		<keybind key="W-A-1">
			<action name="GoToDesktop"><to>1</to></action>
		</keybind>
		<keybind key="W-A-2">
			<action name="GoToDesktop"><to>2</to></action>
