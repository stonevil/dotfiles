			<action name="GoToDesktop"><to>8</to></action>
		</keybind>
		<keybind key="W-A-9">
			<action name="GoToDesktop"><to>9</to></action>
		</keybind>
		<keybind key="W-A-0">
			<action name="GoToDesktop"><to>10</to></action>
		</keybind>

		<keybind key="W-A-S-1">
			<action name="SendToDesktop"><to>1</to></action>
		</keybind>
		<keybind key="W-A-S-2">
			<action name="SendToDesktop"><to>2</to></action>
		</keybind>
		<keybind key="W-A-S-3">
			<action name="SendToDesktop"><to>3</to></action>
		</keybind>
		<keybind key="W-A-S-4">
			<action name="SendToDesktop"><to>4</to></action>
		</keybind>
		<keybind key="W-A-S-5">
			<action name="SendToDesktop"><to>5</to></action>
		</keybind>
		<keybind key="W-A-S-6">
			<action name="SendToDesktop"><to>6</to></action>
		</keybind>
		<keybind key="W-A-S-7">
			<action name="SendToDesktop"><to>7</to></action>
		</keybind>
		<keybind key="W-A-S-8">
			<action name="SendToDesktop"><to>8</to></action>
		</keybind>
