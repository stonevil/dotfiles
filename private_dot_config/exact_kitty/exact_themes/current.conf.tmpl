# The basic colors
foreground {{ print "#" .colours.normal.foreground }}
background {{ if .theme.blackout }}#000000{{ else }}{{ print "#" .colours.normal.background }}{{ end }}
selection_foreground {{ print "#" .colours.selection.text }}
selection_background {{ print "#" .colours.selection.background }}

# Cursor colors
cursor {{ print "#" .colours.cursor.cursor }}
cursor_text_color {{ print "#" .colours.cursor.text }}

# URL underline color when hovering with mouse
url_color {{ print "#" .colours.normal.urls }}

# Kitty window border colors
active_border_color {{ print "#" .colours.normal.blue }}
inactive_border_color {{ print "#" .colours.normal.black }}
bell_border_color {{ print "#" .colours.bright.yellow }}

# OS Window titlebar colors
wayland_titlebar_color system
macos_titlebar_color system

# Tab bar colors
active_tab_foreground {{ print "#" .colours.cursor.text }}
active_tab_background {{ print "#" .colours.cursor.cursor }}
inactive_tab_foreground {{ print "#" .colours.bright.foreground }}
inactive_tab_background {{ print "#" .colours.bright.background }}
tab_bar_background {{ if .theme.blackout }}#000000{{ else }}{{ print "#" .colours.normal.background }}{{ end }}

# Colors for marks (marked text in the terminal)
mark1_foreground {{ print "#" .colours.cursor.text }}
mark1_background {{ print "#" .colours.normal.surface2 }}
mark2_foreground {{ print "#" .colours.cursor.text }}
mark2_background {{ print "#" .colours.normal.surface1 }}
mark3_foreground {{ print "#" .colours.cursor.text }}
mark3_background {{ print "#" .colours.normal.surface0 }}

# The 16 terminal colors

# black
color0 {{ if .theme.blackout }}#000000{{ else }}{{ print "#" .colours.normal.black }}{{ end }}
color8 {{ print "#" .colours.bright.black }}

# red
color1 {{ print "#" .colours.normal.red }}
color9 {{ print "#" .colours.bright.red }}

# green
color2 {{ print "#" .colours.normal.green }}
color10 {{ print "#" .colours.bright.green }}

# yellow
color3 {{ print "#" .colours.normal.yellow }}
color11 {{ print "#" .colours.bright.yellow }}

# blue
color4 {{ print "#" .colours.normal.blue }}
color12 {{ print "#" .colours.bright.blue }}

# magenta
color5 {{ print "#" .colours.normal.magenta }}
color13 {{ print "#" .colours.bright.magenta }}

# cyan
color6 {{ print "#" .colours.normal.cyan }}
color14 {{ print "#" .colours.bright.cyan }}

# white
color7 {{ print "#" .colours.normal.white }}
color15 {{ print "#" .colours.bright.white }}
