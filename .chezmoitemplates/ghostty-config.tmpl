{{- /*
vim:ft=dosini.gotexttmpl
*/ -}}

# TODO: sync keys with wezterm, tmux. Impossible for now. No intergration with NeoVim

#custom-shader = shaders/glitchy.glsl

theme = current

font-family = {{ .env.font | quote }}
font-size = {{ if or (.tags.zephyrus.enabled) (.tags.thinkpad.enabled) }}{{ if ge (4 | sub .env.fontSize) 10 }}{{ 4 | sub .env.fontSize }}{{ else }}{{ .env.fontSize }}{{ end }}{{ else }}{{ .env.fontSize }}{{ end }}

cursor-style = block
cursor-style-blink = true

background-opacity = {{ .env.opacity }}
{{- if lt (.env.opacity | float64) 1.0 }}
background-blur-radius = {{ .env.blur }}
{{ end }}

window-decoration = true
macos-titlebar-style = hidden

copy-on-select = true

macos-option-as-alt = right

macos-icon = custom-style
macos-icon-ghost-color = {{ (print "#" .colours.normal.foreground) | quote }}
macos-icon-screen-color = {{ if .theme.blackout }}"#000000"{{ else }}{{ (print "#" .colours.normal.background) | quote }}{{ end }}

confirm-close-surface = false

auto-update = off

shell-integration = detect

keybind = global:super+option+/=toggle_quick_terminal

